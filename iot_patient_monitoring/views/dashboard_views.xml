<odoo>

    <record id="view_iot_dashboard_form" model="ir.ui.view">
        <field name="name">iot.dashboard.form</field>
        <field name="model">iot.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard" create="false" edit="false" delete="false">
                <sheet>
                    <field name="dashboard_html" widget="html" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="iot_dashboard_main" model="iot.dashboard">
        <field name="name">Dashboard</field>
    </record>

    <record id="action_iot_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">iot.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_iot_dashboard_form"/>
        <field name="res_id" ref="iot_dashboard_main"/>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_iot_dashboard"
              name="Dashboard"
              parent="menu_iot_root"
              action="action_iot_dashboard"
              sequence="0"/>

</odoo>